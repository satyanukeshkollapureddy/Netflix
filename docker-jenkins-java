#!/bin/bash
set -e

echo "============================"
echo "UPDATING SYSTEM"
echo "============================"
dnf update -y

echo "============================"
echo "INSTALL JAVA 21 (MANDATORY FOR NEW JENKINS)"
echo "============================"
dnf install -y java-21-amazon-corretto

java -version

echo "============================"
echo "SET JAVA 21 AS DEFAULT"
echo "============================"
alternatives --set java /usr/lib/jvm/java-21-amazon-corretto.x86_64/bin/java || true

echo "============================"
echo "INSTALL DOCKER"
echo "============================"
dnf install -y docker
systemctl enable docker
systemctl start docker

# Add default users to docker group
usermod -aG docker ec2-user || true
usermod -aG docker jenkins || true

echo "============================"
echo "INSTALL NODEJS (FOR JS APPS)"
echo "============================"
dnf install -y nodejs npm

node -v
npm -v

echo "============================"
echo "INSTALL JENKINS"
echo "============================"

wget -O /etc/yum.repos.d/jenkins.repo \
    https://pkg.jenkins.io/redhat-stable/jenkins.repo

rpm --import https://pkg.jenkins.io/redhat-stable/jenkins.io-2023.key

dnf install -y jenkins

echo "============================"
echo "CONFIGURE JAVA FOR JENKINS"
echo "============================"
sed -i 's|^JAVA=.*|JAVA=/usr/lib/jvm/java-21-amazon-corretto/bin/java|g' /etc/sysconfig/jenkins || true

echo "JAVA_HOME=/usr/lib/jvm/java-21-amazon-corretto" >> /etc/sysconfig/jenkins || true

echo "============================"
echo "ENABLE SERVICES"
echo "============================"
systemctl enable docker
systemctl start docker

systemctl enable jenkins
systemctl start jenkins

echo "============================"
echo "FIX PERMISSIONS"
echo "============================"
chown -R jenkins:jenkins /var/lib/jenkins || true

echo "============================"
echo "OPEN FIREWALL PORT (OPTIONAL)"
echo "============================"
firewall-cmd --permanent --add-port=8080/tcp || true
firewall-cmd --reload || true

echo "============================"
echo "FINAL STATUS"
echo "============================"
systemctl status docker --no-pager || true
systemctl status jenkins --no-pager || true

echo "============================"
echo "GET JENKINS PASSWORD"
echo "============================"
cat /var/lib/jenkins/secrets/initialAdminPassword || true

echo "============================"
echo "SETUP COMPLETE"
echo "============================"
echo "Open: http://<EC2-PUBLIC-IP>:8080"
