pipeline {
agent any


tools {
    jdk 'jdk23'
    nodejs 'node18'
}

environment {
    SCANNER_HOME = tool 'sonar-scanner'
    DOCKER_IMAGE = "sandy315/tetrisv1"
    IMAGE_TAG = "${BUILD_NUMBER}"
    FULL_IMAGE_NAME = "${DOCKER_IMAGE}:${IMAGE_TAG}"
}

options {
    timestamps()
    buildDiscarder(logRotator(numToKeepStr: '10'))
}

stages {

    stage('Clean Workspace') {
        steps {
            cleanWs()
        }
    }

    stage('Checkout Source Code') {
        steps {
            git branch: 'main',
                url: 'https://github.com/satyanukeshkollapureddy/devsecops-Tetris-V1.git'
        }
    }

    stage('SonarQube Analysis') {
        steps {
            withSonarQubeEnv('sonar') {
                sh """
                ${SCANNER_HOME}/bin/sonar-scanner \
                -Dsonar.projectName=tetris \
                -Dsonar.projectKey=tetris \
                -Dsonar.sources=.
                """
            }
        }
    }

    stage('Quality Gate') {
        steps {
            timeout(time: 10, unit: 'MINUTES') {
                waitForQualityGate abortPipeline: true
            }
        }
    }

    stage('Install Dependencies') {
        steps {
            sh 'npm install'
        }
    }

    stage('Build Application') {
        steps {
            sh 'npm run build || true'
        }
    }

    stage('Trivy File System Scan') {
        steps {
            sh '''
            trivy fs . --format table > trivyfs.txt || true
            '''
        }
    }

    stage('Docker Build') {
        steps {
            sh """
            docker build -t ${FULL_IMAGE_NAME} .
            """
        }
    }

    stage('Trivy Image Scan') {
        steps {
            sh """
            trivy image ${FULL_IMAGE_NAME} --format table > trivyimage.txt || true
            """
        }
    }

    stage('Push Image to DockerHub') {
    steps {
        withDockerRegistry(
            credentialsId: 'docker',
            url: 'https://index.docker.io/v1/'
        ) {
            sh "docker push ${FULL_IMAGE_NAME}"
        }
    }
}
    stage('Checkout Manifest Repository') {
        steps {
            dir('manifest-repo') {
                git branch: 'main',
                    credentialsId: 'github',
                    url: 'https://github.com/satyanukeshkollapureddy/devsecops-tetris-manifest.git'
            }
        }
    }

    stage('Update Kubernetes Manifest') {
        steps {
            dir('manifest-repo') {

                withCredentials([
                    string(
                        credentialsId: 'github',
                        variable: 'GITHUB_TOKEN'
                    )
                ]) {

                    sh """
                    sed -i 's|image:.*|image: ${FULL_IMAGE_NAME}|g' deployment.yml

                    git config user.name "Jenkins"
                    git config user.email "jenkins@example.com"

                    git add deployment.yml

                    git diff --cached --quiet || \
                    git commit -m "Update image to ${FULL_IMAGE_NAME}"

                    git push https://x-access-token:${GITHUB_TOKEN}@github.com/satyanukeshkollapureddy/devsecops-tetris-manifest.git HEAD:main
                    """
                }
            }
        }
    }
}

post {

    always {
        archiveArtifacts artifacts: '*.txt', allowEmptyArchive: true
        cleanWs()
    }

    success {
        echo 'Pipeline executed successfully!'
    }

    failure {
        echo 'Pipeline execution failed!'
    }
}


}
